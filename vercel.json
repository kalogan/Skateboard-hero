{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @skate/web build",
  "outputDirectory": "apps/web/dist",
  "github": {
    "silent": true
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
