{
  "name": "skateboard-hero",
  "version": "0.0.0",
  "private": true,
  "description": "Skateboard Hero — an endless one-button dodge-runner, built with the Architect–Builder Pipeline.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r --no-bail typecheck",
    "lint": "eslint .",
    "lint:content": "tsx scripts/lint-content.ts",
    "test": "pnpm -r --no-bail test",
    "build": "pnpm -r build",
    "gate": "bash gate.sh",
    "dev": "pnpm --filter @skate/web dev",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@skate/core": "workspace:*",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "playwright": "1.56.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
